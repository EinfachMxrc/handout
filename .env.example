# ================================================================
# Slide Handout – Umgebungsvariablen (Übersicht)
# ================================================================
#
# SETUP (einmalig, lokal):
#   1.  npx convex dev        → erstellt Root-.env.local automatisch
#   2.  pnpm setup            → kopiert URL in apps/web und apps/powerpoint-addin
#
# FÜR PRODUKTIONS-DEPLOYMENTS (Netlify, Railway, Render, VPS, ...):
#   Setze diese Variable in der Plattform-UI oder in der Server-.env:
#
#     NEXT_PUBLIC_CONVEX_URL=https://dein-projekt.convex.cloud
#
# ================================================================

# ---- Von Convex CLI automatisch verwaltet (Root-.env.local) ----
# (Nicht manuell bearbeiten – wird von `npx convex dev` geschrieben)

CONVEX_DEPLOYMENT=dev:dein-projekt-name
CONVEX_URL=https://dein-projekt.convex.cloud
CONVEX_SITE_URL=https://dein-projekt.convex.site

# ---- Web-App (apps/web/.env.local) ----
# Wird von `pnpm setup` automatisch gesetzt.

NEXT_PUBLIC_CONVEX_URL=https://dein-projekt.convex.cloud

# ---- PowerPoint Add-in (apps/powerpoint-addin/.env.local) ----
# Wird von `pnpm setup` automatisch gesetzt.
# Dieser Wert wird im Add-in als Standard-Convex-URL vorausgefüllt.

VITE_CONVEX_URL=https://dein-projekt.convex.cloud
