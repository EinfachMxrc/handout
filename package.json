{
  "name": "slide-handout-root",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter powerpoint-addin dev\"",
    "dev:all": "concurrently \"pnpm --filter web dev\" \"pnpm --filter powerpoint-addin dev\" \"pnpm --filter convex-backend dev\"",
    "dev:web": "pnpm --filter web dev",
    "dev:addin": "pnpm --filter powerpoint-addin dev",
    "dev:convex": "npx convex dev --run init:init",
    "seed": "npx convex run init:init",
    "setup": "node scripts/setup-env.mjs",
    "build": "turbo run build --filter=@slide-handout/shared --filter=@slide-handout/reveal-engine --filter=web --filter=powerpoint-addin",
    "build:legacy": "pnpm --filter reveal-engine build && pnpm --filter shared build && pnpm --filter web build && pnpm --filter powerpoint-addin build",
    "test": "turbo run test --filter=@slide-handout/reveal-engine",
    "test:all": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "dependencies": {
    "convex": "^1.35.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "turbo": "^2.5.8",
    "typescript": "^6.0.2"
  }
}
